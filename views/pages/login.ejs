<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login</title>
    <link rel="stylesheet" href="styles/index.css" >
    <link rel="stylesheet" href="styles/login-register.css" >
</head>
<body>
    <% if(error) { %>
        <p class="error-msg" ><%= error.status %> | <%= error.message %></p>
    <% } %>
    <form method="post" >
        <h1>Login</h1>

        <input type="text" name="email" placeholder="Write your email..." value="<%= lastData.email || '' %>" >

        <input type="password" name="password" placeholder="Write your password..." value="<%= lastData.password || '' %>" >

        <input type="submit" value="Login" >

        <p>Don't have an account? <a href="/register" >Register</a>!</p>
    </form>
</body>
</html>